# 後端串口設定（範例）
# SERIAL_PORTS=/dev/ttys000
DEVICE_NAMES=CH-01,CH-02,CH-03,CH-04,CH-05

# 資料庫設定
DATABASE_URL=sqlite:///./test.db

# Demo Master Key（後備用，正常情況請改用 UI 管理訪客 Token）
# 本機開發可留空，後端會跳過所有驗證
# 部署時建議填入，作為管理者緊急存取的後備密碼
DEMO_PASSWORD=your_master_key_here

# Gemini API（AI 諮詢 + RAG embedding，Google AI Studio 免費申請）
GEMINI_API_KEY=your_gemini_api_key_here

# LINE Bot（選填，不填則停用推播功能）
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# RAG Embedding 設定（選填，預設使用 Gemini）
# RAG_EMBED_PROVIDER=gemini                           # gemini（預設）或 sentence_transformers
# RAG_ST_MODEL=intfloat/multilingual-e5-small         # 僅 sentence_transformers 模式
